{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "schedule": ["before 9am on Monday"],
  "prCreation": "not-pending",
  "labels": ["dependencies"],
  "docker": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/anomalyco/opencode"],
      "enabled": true,
      "pinDigests": false
    }
  ]
}
